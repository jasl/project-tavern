{
  "name": "project-tavern-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "format:check": "prettier --check .",
    "verify:docs": "node scripts/docs/verify-docs.mjs",
    "lint": "oxlint --type-aware --deny-warnings --react-plugin --import-plugin engine game scripts",
    "lint:styles": "stylelint \"engine/packages/**/*.css\" \"game/packages/**/*.css\" \"game/stories/**/*.css\"",
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -p tsconfig.check.json --noEmit --pretty false",
    "verify:boundaries": "node scripts/verify-boundaries.mjs",
    "verify:cycles": "node scripts/verify-cycles.mjs",
    "verify:public-exports": "node scripts/verify-public-exports.mjs",
    "verify:stories": "node scripts/verify-stories.mjs",
    "verify:fixtures": "node scripts/verify-fixtures.mjs",
    "verify:golden": "node scripts/verify-golden.mjs",
    "verify:balance": "node scripts/verify-poc-balance.mjs",
    "verify:balance:smoke": "node scripts/verify-poc-balance.mjs --smoke",
    "verify:determinism": "pnpm --filter @project-tavern/story-e2e verify:determinism",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify:bundle": "node scripts/verify-bundle.mjs",
    "verify:artifact": "node scripts/verify-artifact.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:ui": "node --experimental-strip-types scripts/ui/verify-ui.mts",
    "test:unit": "vitest run --project unit",
    "test:contract": "vitest run --project contract",
    "test:property": "vitest run --project property",
    "test:node": "node scripts/run-script-tests.mjs --kind mjs",
    "test:scripts": "node scripts/run-script-tests.mjs",
    "test": "pnpm test:unit && pnpm test:contract && pnpm test:property",
    "test:e2e:smoke": "playwright test --project=chromium --grep @smoke",
    "test:e2e:full": "playwright test --project=chromium --project=webkit",
    "test:e2e:interaction": "playwright test --config engine/packages/web/playwright.interaction.config.ts",
    "build:e2e": "vite build --config ./vite.config.ts --mode e2e-web",
    "build:poc": "vite build --config ./vite.config.ts --mode poc-web",
    "update:screenshots": "playwright test --project=chromium --grep @visual --update-snapshots",
    "update:materialization-lock": "node --experimental-strip-types scripts/preflight/materialization-contract.mts --write",
    "prepare:goal": "node --experimental-strip-types scripts/preflight/materialize-goal.mts",
    "verify:materialization": "node --experimental-strip-types scripts/preflight/verify-materialization.mts",
    "verify:semantic": "node --experimental-strip-types scripts/verify-semantic.mts",
    "verify:phase2": "node --experimental-strip-types scripts/verify-phase2-runtime.mts",
    "verify:runtime-fixtures": "pnpm --filter @project-tavern/story-e2e verify:runtime-fixtures",
    "verify:persistence-diagnostics": "node --experimental-strip-types scripts/verify-persistence-diagnostics.mts",
    "verify:poc-gameplay": "node --experimental-strip-types scripts/verify-poc-gameplay.mts",
    "verify:poc-story": "node --experimental-strip-types scripts/verify-poc-story.mts",
    "verify:phase4": "pnpm verify:poc-gameplay && pnpm verify:poc-story",
    "verify:phase5a": "pnpm verify:phase4 && pnpm verify:ui",
    "verify:story-presentation": "node --experimental-strip-types scripts/ui/verify-stage-presentation.mts",
    "verify:phase5b": "pnpm verify:phase5a && pnpm verify:story-presentation",
    "verify:application-graphs": "node --experimental-strip-types scripts/ui/verify-application-graphs.mts",
    "release:prepare": "pnpm build:e2e && node scripts/prepare-artifact.mjs dist/e2e",
    "regenerate:fixtures": "pnpm --filter @project-tavern/story-e2e regenerate:fixtures",
    "update:golden": "pnpm --filter @project-tavern/story-e2e update:golden",
    "verify": "node scripts/verify.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "fast-check": "4.9.0",
    "jsdom": "29.1.1",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
