{
  "name": "project-tavern-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite --mode poc-web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --type-aware --deny-warnings --react-plugin --import-plugin engine game scripts vite.config.ts vitest.config.ts",
    "lint:styles": "stylelint \"engine/packages/**/*.css\" \"game/packages/**/*.css\" \"game/stories/**/*.css\"",
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -p tsconfig.check.json --noEmit --pretty false",
    "test:unit": "vitest run",
    "test:node": "node --test scripts/*.test.mjs",
    "test": "pnpm test:unit && pnpm test:node",
    "check:assets": "node --experimental-strip-types scripts/assets/verify-runtime-assets.mts",
    "test:e2e:smoke": "playwright test --config engine/packages/web/playwright.ui.config.ts --project=chromium --grep @smoke",
    "test:e2e": "playwright test --config engine/packages/web/playwright.ui.config.ts --project=chromium --project=webkit",
    "test:e2e:interaction": "playwright test --config engine/packages/web/playwright.interaction.config.ts",
    "build:poc": "vite build --mode poc-web",
    "release:poc": "pnpm build:poc && node --experimental-strip-types scripts/prepare-artifact.mjs dist/poc",
    "test:e2e:prebuilt": "playwright test --config engine/packages/web/playwright.prebuilt.config.ts",
    "test:release": "pnpm release:poc && pnpm test:e2e:prebuilt",
    "check": "pnpm format:check && pnpm lint && pnpm lint:styles && pnpm typecheck && pnpm test && pnpm check:assets && pnpm build:poc",
    "verify": "pnpm check"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "fast-check": "4.9.0",
    "jsdom": "29.1.1",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
