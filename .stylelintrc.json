{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "selector-class-pattern": [
      "^[a-z][a-z0-9-]*(?:__[a-z0-9-]+)?(?:--[a-z0-9-]+)?$",
      {
        "message": "Expected CSS Modules classes to use kebab-case or reviewed BEM syntax"
      }
    ]
  },
  "overrides": [
    {
      "files": ["engine/packages/web/src/styles.css"],
      "rules": {
        "rule-empty-line-before": "never"
      }
    }
  ]
}
