{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./tsconfig.application.tsbuildinfo",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "include": [
    "src/application/**/*.ts",
    "src/application/**/*.tsx",
    "src/presentation/e2e-settings-section.tsx",
    "src/presentation/runtime-presentation.ts",
    "src/presentation/ui-contributions.tsx"
  ],
  "exclude": ["src/application/**/*.test.ts", "src/application/**/*.test.tsx"],
  "references": [
    { "path": "." },
    { "path": "../../../engine/packages/base" },
    { "path": "../../../engine/packages/ui" },
    { "path": "../../../engine/packages/web" }
  ]
}
