{
  "name": "@project-tavern/story-e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "PolyForm-Noncommercial-1.0.0",
  "exports": {
    ".": "./src/index.ts",
    "./tooling": "./src/tooling.ts"
  },
  "scripts": {
    "test": "pnpm --workspace-root exec vitest run game/stories/e2e/src",
    "test:runtime": "pnpm --dir ../../.. exec vitest run game/stories/e2e/src/runtime game/stories/e2e/src/tooling",
    "verify:fixtures": "node --experimental-strip-types scripts/verify-fixtures.mts",
    "regenerate:fixtures": "node --experimental-strip-types scripts/regenerate-fixtures.mts",
    "regenerate:runtime-fixtures": "node --experimental-strip-types scripts/regenerate-runtime-fixtures.mts",
    "verify:runtime-fixtures": "node --experimental-strip-types scripts/verify-runtime-fixtures.mts",
    "verify:golden": "node --experimental-strip-types scripts/verify-golden.mts",
    "update:golden": "node --experimental-strip-types scripts/update-golden.mts",
    "update:source-digests": "node --experimental-strip-types scripts/update-source-digests.mts",
    "verify:determinism": "node --experimental-strip-types scripts/verify-determinism.mts",
    "verify:semantic": "pnpm --workspace-root exec vitest run game/stories/e2e/src/runtime/e2e-semantic-game-port.test.ts game/stories/e2e/src/runtime/headless-runner.test.ts"
  },
  "dependencies": {
    "@sillymaker/base": "workspace:*",
    "@sillymaker/ui": "workspace:*",
    "@project-tavern/assets": "workspace:*",
    "@sillymaker/web": "workspace:*",
    "react": "19.2.7",
    "zod": "4.4.3"
  }
}
