{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.test-d.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "stories/**/*.ts",
    "stories/**/*.tsx",
    "scripts/**/*.test.ts",
    "scripts/**/*.d.mts",
    "vitest.config.ts"
  ],
  "exclude": ["**/dist/**", "node_modules/**"]
}
