{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"]
  },
  "include": [
    "engine/**/*.ts",
    "engine/**/*.tsx",
    "engine/**/*.test-d.ts",
    "game/**/*.ts",
    "game/**/*.tsx",
    "game/**/*.test-d.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "vitest.config.ts",
    "vite.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["**/dist/**", "node_modules/**"]
}
